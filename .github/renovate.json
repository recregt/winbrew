{
  "schedule": ["before 5am on the first day of the month"],
  "semanticCommits": "enabled",
  "configMigration": true,
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 0,
  "vulnerabilityAlerts": {
    "schedule": ["at any time"],
    "labels": ["dependencies", "security"]
  },
  "enabledManagers": ["cargo", "gomod", "npm", "github-actions", "custom.regex"],
  "ignorePaths": ["**/tests/**"],
  "ignoreDeps": ["curl-sys"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Cargo\\.toml$/"],
      "matchStrings": [
        "\\bMSRV:3\\b.*?(?<currentValue>\\d+\\.\\d+(\\.\\d+)?)",
        "(?<currentValue>\\d+\\.\\d+(\\.\\d+)?).*?\\bMSRV:3\\b"
      ],
      "depNameTemplate": "MSRV:3",
      "packageNameTemplate": "rust-lang/rust",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)rust-toolchain\\.toml$/"],
      "matchStrings": [
        "channel\\s*=\\s*\"(?<currentValue>\\d+\\.\\d+(\\.\\d+)?)\""
      ],
      "depNameTemplate": "rust-toolchain",
      "packageNameTemplate": "rust-lang/rust",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)crates/app/src/operations/install/sevenz\\.rs$/"],
      "matchStrings": [
        "const\\s+SEVENZ_BOOTSTRAP_VERSION:\\s*&str\\s*=\\s*\"(?<currentValue>\\d+\\.\\d+)\";"
      ],
      "depNameTemplate": "7zip",
      "packageNameTemplate": "ip7z/7zip",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-update"],
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "30 days",
      "labels": ["dependencies", "major-update"],
      "automerge": false
    },
    {
      "commitMessageTopic": "Rust toolchain & MSRV",
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["MSRV:3", "rust-toolchain"],
      "extractVersion": "^(?<version>\\d+\\.\\d+)",
      "schedule": ["at any time"],
      "minimumReleaseAge": "85 days",
      "internalChecksFilter": "strict",
      "groupName": "msrv"
    },
    {
      "commitMessageTopic": "7-Zip bootstrap",
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["7zip"],
      "extractVersion": "^(?<version>\\d+\\.\\d+)",
      "schedule": ["at any time"],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "groupName": "bootstrap"
    },
    {
      "matchManagers": ["cargo"],
      "matchCurrentVersion": "<1.0.0",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": false,
      "groupName": "compatible-cargo-pre1",
      "minimumReleaseAge": "7 days",
      "internalChecksFilter": "strict"
    },
    {
      "matchManagers": ["cargo"],
      "matchCurrentVersion": ">=1.0.0",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": false,
      "groupName": "compatible-cargo",
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict"
    },
    {
      "matchManagers": ["gomod"],
      "matchCurrentVersion": "<1.0.0",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": false,
      "groupName": "compatible-go-pre1",
      "minimumReleaseAge": "7 days",
      "internalChecksFilter": "strict"
    },
    {
      "matchManagers": ["gomod"],
      "matchCurrentVersion": ">=1.0.0",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": false,
      "groupName": "compatible-go",
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict"
    },
    {
      "matchManagers": ["npm"],
      "matchCurrentVersion": ">=0.1.0",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": false,
      "groupName": "compatible-npm",
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": false,
      "groupName": "compatible-actions",
      "minimumReleaseAge": "7 days",
      "internalChecksFilter": "strict"
    }
  ]
}